{
  "rules": {
    "rooms": {
      "$roomCode": {
        ".read": true,
        ".write": true,
        "players": {
          ".indexOn": ["joinedAt", "name"]
        },
        "drawing": {
          ".indexOn": ["timestamp"]
        },
        "chat": {
          ".indexOn": ["timestamp"]
        }
      }
    }
  }
}
